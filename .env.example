# Tableau authentication
ts_token="your-personal-access-token-name"
ts_secret="your-personal-access-token-secret"
api_version="3.21"
server_url="https://tableau.yourdomain.com"

# Snowflake credentials
# sf_username    — the username to set on all matching connections
# sf_password    — the new password to embed
# sf_old_username — optional: only needed when migrating to a new username.
#                   Set this to the current (old) username to enable migration mode.
#                   Leave blank or omit entirely for a standard password rotation.
sf_username="YOUR_USERNAME@YOURDOMAIN.EDU"
sf_password="your-new-snowflake-password"
sf_old_username=""
